APP_ENV=development

OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
USE_NVIDIA_NIM_TEXT_LLM=false
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=qwen/qwen3.5-397b-a17b
NVIDIA_NIM_TIMEOUT_SECONDS=300
LLM_MODEL=deepseek/deepseek-v4-flash
TOPIC_LLM_MODEL=deepseek/deepseek-v4-flash
SCRIPT_LLM_MODEL=deepseek/deepseek-v4-pro
DIRECTION_LLM_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
LLM_FALLBACK_MODEL=qwen/qwen3.5-flash-02-23
SKILLS_PATH=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_RO=
ELEVENLABS_VOICE_ID_EN=

SEARCH_API_KEY=
SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_TIMEOUT_SECONDS=30
SEARXNG_PUBLIC_BASE_URL=http://localhost:8080/
SEARXNG_SECRET=
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-lite-image

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

N8N_WEBHOOK_URL=
INTERNAL_API_TOKEN=

DEFAULT_VIDEO_WIDTH=1080
DEFAULT_VIDEO_HEIGHT=1920
DEFAULT_VIDEO_FPS=30
DEFAULT_AUDIO_SAMPLE_RATE=44100

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

MASCOT_SET=default
