MASCOT_ENV_FILE=./.env.automation.example
MASCOT_OUTPUT_DIR=./output
MASCOT_DATA_DIR=./data
MASCOT_POSTGRES_DIR=./.local/postgres
POSTGRES_DB=mascot
POSTGRES_USER=mascot
POSTGRES_PASSWORD=replace-with-a-long-random-password
AUTOMATION_INTERNAL_API_TOKEN=replace-with-a-long-random-token
AUTOMATION_TELEGRAM_BOT_TOKEN=replace-with-botfather-token
AUTOMATION_TELEGRAM_ALLOWED_USER_ID=123456789
AUTOMATION_TELEGRAM_REVIEW_CHAT_ID=123456789
AUTOMATION_R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
AUTOMATION_R2_ACCESS_KEY_ID=replace-with-r2-access-key
AUTOMATION_R2_SECRET_ACCESS_KEY=replace-with-r2-secret-key
AUTOMATION_R2_BUCKET=mascot-buffer-media
AUTOMATION_R2_PUBLIC_BASE_URL=https://media.example.com
AUTOMATION_BUFFER_API_TOKEN=replace-with-buffer-api-key
AUTOMATION_BUFFER_TIKTOK_CHANNEL_ID=replace-with-buffer-channel-id
OPENROUTER_API_KEY=replace-with-openrouter-key
ELEVENLABS_API_KEY=replace-with-elevenlabs-key
SEARXNG_SECRET=replace-with-a-long-random-secret
